generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TopUpLoanCalculation {
  id           Int      @id @default(autoincrement())
  existingLoan Float
  existingEMI  Float
  topUpAmount  Float
  interestRate Float
  tenure       Int
  createdAt    DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String             @id @default(cuid())
  name                    String?
  email                   String?            @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  passwordChangedAt       DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  occupation              String?
  purpose                 String?
  age                     Int?
  phone                   String?
  city                    String?
  state                   String?
  country                 String?
  education               String?
  organization            String?
  experienceYears         Int?
  goals                   String?
  preferredLanguage       String?
  personalizationOptIn    Boolean            @default(false)
  adsPersonalizationOptIn Boolean            @default(false)
  totalCalculations       Int                @default(0)
  totalSearches           Int                @default(0)
  themeChanges            Int                @default(0)
  lastVisit               DateTime           @default(now())
  favoriteCategory        String?
  mostUsedCalculator      String?
  role                    UserRole           @default(USER)
  accounts                Account[]
  activityLogs            ActivityLog[]
  apiKeys                 ApiKey[]
  blogPosts               BlogPost[]
  calculations            Calculation[]
  favorites               Favorite[]
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  savedResults            SavedResult[]
  sessions                Session[]
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  url       String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Calculation {
  id             String   @id @default(cuid())
  userId         String
  calculatorType String
  calculatorName String
  category       String
  inputs         String
  result         String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([calculatorType])
}

model Favorite {
  id             String    @id @default(cuid())
  userId         String
  calculatorId   String
  calculatorName String
  category       String
  description    String?
  usageCount     Int       @default(0)
  lastUsed       DateTime?
  addedAt        DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, calculatorId])
  @@index([userId])
}

model SavedResult {
  id             String   @id @default(cuid())
  userId         String
  calculatorType String
  calculatorName String
  inputs         String
  result         String
  notes          String?
  tags           String?
  savedAt        DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, savedAt])
  @@index([calculatorType])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)

  @@index([email])
}

model ApiKey {
  id         String     @id @default(cuid())
  userId     String
  name       String
  key        String     @unique
  tier       String     @default("FREE")
  isActive   Boolean    @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime   @default(now())
  expiresAt  DateTime?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage      ApiUsage[]

  @@index([userId])
  @@index([key])
}

model ApiUsage {
  id         String   @id @default(cuid())
  apiKeyId   String
  endpoint   String
  method     String
  statusCode Int
  timestamp  DateTime @default(now())
  ipAddress  String?
  userAgent  String?
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, timestamp])
  @@index([timestamp])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model NotificationEvent {
  id         String   @id @default(cuid())
  title      String
  body       String
  url        String?
  icon       String?
  sentCount  Int      @default(0)
  errorCount Int      @default(0)
  createdAt  DateTime @default(now())
}

model Category {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  icon            String?
  description     String?
  calculatorCount Int          @default(0)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  calculators     Calculator[]

  @@index([slug])
}

model Calculator {
  id           String                  @id @default(cuid())
  slug         String                  @unique
  categoryId   String?
  subcategory  String?
  totalUses    Int                     @default(0)
  isActive     Boolean                 @default(true)
  isFeatured   Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  blogPosts    BlogPost[]
  category     Category?               @relation(fields: [categoryId], references: [id])
  translations CalculatorTranslation[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
}

model CalculatorTranslation {
  id           String     @id @default(cuid())
  calculatorId String
  language     String
  title        String
  description  String?
  metaTitle    String?
  metaDesc     String?
  isPublished  Boolean    @default(false)
  calculator   Calculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)

  @@unique([calculatorId, language])
  @@index([calculatorId])
  @@index([language])
}

model BlogPost {
  id                 String                @id @default(cuid())
  slug               String                @unique
  category           String?
  linkedCalculatorId String?
  featuredImage      String?
  tags               String[]              @default([])
  authorId           String?
  status             BlogStatus            @default(DRAFT)
  scheduledAt        DateTime?
  viewCount          Int                   @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  subcategory        String?
  author             User?                 @relation(fields: [authorId], references: [id])
  calculator         Calculator?           @relation(fields: [linkedCalculatorId], references: [id])
  translations       BlogPostTranslation[]

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([category])
  @@index([linkedCalculatorId])
}

model BlogPostTranslation {
  id          String    @id @default(cuid())
  blogPostId  String
  language    String
  title       String
  content     String
  metaTitle   String?
  metaDesc    String?
  urlSlug     String    @unique
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  wordCount   Int       @default(0)
  blogPost    BlogPost  @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, language])
  @@index([blogPostId])
  @@index([language])
  @@index([urlSlug])
}

model AdminApiKey {
  id         String   @id @default(cuid())
  clientName String
  keyHash    String   @unique
  plan       ApiPlan  @default(FREE)
  callsLimit Int      @default(100)
  callsUsed  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([keyHash])
  @@index([isActive])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([entityType])
}

model Revenue {
  id        String   @id @default(cuid())
  source    String
  amount    Float
  currency  String   @default("USD")
  month     Int
  year      Int
  notes     String?
  createdAt DateTime @default(now())

  @@unique([source, month, year])
  @@index([year, month])
}

model SEOKeyword {
  id           String   @id @default(cuid())
  keyword      String   @unique
  targetUrl    String?
  volume       Int      @default(0)
  currentRank  Int?
  previousRank Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([keyword])
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  VIEWER
  USER
}

enum BlogStatus {
  DRAFT
  REVIEW
  PUBLISHED
  SCHEDULED
}

enum ApiPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}
